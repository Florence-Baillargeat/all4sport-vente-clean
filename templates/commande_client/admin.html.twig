{% extends 'base.html.twig' %}

{% block title %}Les commandes{% endblock %}

{% block body %}



<style>

.content {
	display: flex;
	flex-direction: column;
	align-items: center;

	width: 100%;
}

.filter {
	width: 100%;
	height: 70px;
	background: red;

	display: flex;
	justify-content: flex-end;
	align-items: center;
}

/* Container principal pour chaque commande */
.commande-card {
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 20px;
    background-color: #f9f9f9;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    transition: transform 0.2s;

		width: 80%;
}

.commande-card:hover {
    transform: translateY(-3px);
}

/* Header de la commande */
.commande-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    font-weight: bold;
    font-size: 16px;
}

.commande-id {
    color: #333;
}

.commande-date {
    color: #666;
    font-size: 14px;
}

/* Select du statut */
select {
    padding: 6px 10px;
    border-radius: 4px;
    border: 1px solid #ccc;
    background-color: #fff;
    margin-bottom: 12px;
    cursor: pointer;
    font-size: 14px;
}

/* Input de recherche */
input[type="text"] {
    padding: 6px 10px;
    border-radius: 4px;
    border: 1px solid #ccc;
    font-size: 14px;
    margin-left: 10px;
}

/* Produits */
.commande-produits h4 {
    margin-bottom: 8px;
    color: #222;
}

.commande-produits ul {
    list-style-type: none;
    padding-left: 0;
}

.commande-produits li {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    border-bottom: 1px solid #eee;
}

.produit-nom {
    font-weight: 500;
    color: #333;
}

.produit-infos {
    color: #555;
}

/* Container pour filtre et recherche */
div > select, div > input[type="text"] {
    margin-bottom: 16px;
}

/* Responsive */
@media (max-width: 600px) {
    .commande-header {
        flex-direction: column;
        align-items: flex-start;
    }

    .commande-produits li {
        flex-direction: column;
        align-items: flex-start;
    }

    .produit-infos {
        margin-top: 4px;
    }

    div > input[type="text"] {
        margin-left: 0;
        margin-top: 8px;
        width: 100%;
    }
}

</style>

<div class="content"> 

	<div class="filter">


        <select>
					<option> Tous</option>
          {% for statut in statutsCommande %}
            	<option value="{{ statut.id }}">{{ statut.libelle }}</option>
					{% endfor %}
        </select>


		<input type="text">

	</div>


{% for commande in commandes %}
    <div class="commande-card">

        <div class="commande-header">
            <span class="commande-id">Commande #{{ commande.id }}</span>
            <span class="commande-date">Date de commande : {{ commande.dateCommande|date('d/m/Y') }}</span>
        </div>

        <select>
          {% for statut in statutsCommande %}
            {% if statut.id == commande.statutCommandeId.id %}
            	<option value="{{ commande.statutCommandeId.id }}" selected>{{ statut.libelle }}</option>
            {% else %}
            	<option value="{{ statut.id }}">{{ statut.libelle }}</option>
						{% endif %}
					{% endfor %}
        </select>

        <div class="commande-produits">
            <h4>Produits :</h4>
            <ul>
                {% for item in commande.contenir %}
                    <li>
                        <span class="produit-nom">
                            {{ item.produit.libelle }}
                        </span>
                        <span class="produit-infos">
                            x{{ item.quantite }} • {{ item.PrixUnitaire }} €
                        </span>
                    </li>
                {% endfor %}
            </ul>
        </div>

    </div>
{% endfor %}


</div>

{% endblock %}