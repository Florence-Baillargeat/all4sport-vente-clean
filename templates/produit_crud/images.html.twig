{% extends 'base.html.twig' %}

{% block title %}Produit index{% endblock %}

{% block body %}

<style>
<style>

/* ============================= */
/* Galerie d'images */
/* ============================= */
.images-container {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
    margin-top: 30px;
}

.image-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #fff;
    padding: 15px;
    border-radius: 12px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s, box-shadow 0.3s;
}

.image-content:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 25px rgba(0, 0, 0, 0.15);
}

.image-content img {
    border-radius: 12px;
    width: 280px;
    object-fit: cover;
    margin-bottom: 10px;
    transition: transform 0.3s, box-shadow 0.3s;
}

.image-content img:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

/* ============================= */
/* Formulaire d’ajout d’image */
/* ============================= */
form {
    background: #ffffff;
    padding: 25px;
    max-width: 420px;
    margin: 40px auto;
    border-radius: 14px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.3s;
}

form:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
}

/* Preview image */
#imagePreview {
    display: block;
    width: 100%;
    max-height: 220px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 20px;
    border: 2px dashed #bbb;
    transition: border-color 0.3s;
}

#imagePreview:hover {
    border-color: #3498db;
}

/* Input text */
input[type="text"] {
    width: 100%;
    padding: 12px 14px;
    margin-bottom: 15px;
    border-radius: 10px;
    border: 1px solid #ccc;
    outline: none;
    font-size: 1rem;
    transition: border 0.3s, box-shadow 0.3s;
}

input[type="text"]:focus {
    border-color: #3498db;
    box-shadow: 0 0 8px rgba(52, 152, 219, 0.3);
}

/* Boutons */
button {
    width: 100%;
    padding: 12px;
    border: none;
    border-radius: 10px;
    background: linear-gradient(135deg, #3498db, #2980b9);
    color: #fff;
    font-weight: bold;
    font-size: 1rem;
    cursor: pointer;
    transition: transform 0.2s, background 0.3s, box-shadow 0.3s;
}

button:hover {
    background: linear-gradient(135deg, #2980b9, #1c5980);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

/* Responsive */
@media (max-width: 500px) {
    .image-content img {
        width: 90%;
    }

    form {
        padding: 20px;
        margin: 20px;
    }
}
</style>
</style>

<div class="images-container">
    {% for image in images %}
        <div class="image-content" style="display: inline-block; margin: 10px; text-align: center;">
            <img src="{{ image.url }}" width="280px">
            <form method="post" action="{{ path('app_image_delete', {'id': image.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ image.id) }}">
                <button class="btn">Delete</button>
            </form>

        </div>
    {% endfor %}
</div>

<form action="{{ path('app_produit_add_image', {'id': produitId}) }}" method="POST"> 

	<img src="" id="imagePreview">

	<input type="text" name="image" id="inputUrl">
	<button> Ajouter</button>

</form>

<script src="{{asset('javascripts/images_produit.js')}}"></script>

{% endblock %}
