{% extends 'base.html.twig' %}

{% block title %}Votre panier{% endblock %}

{% block body %}
<link href="{{ asset('styles/panier.css') }}" rel="stylesheet" type="text/css"/>

<div class="panier-container">

    

    <div class="panier-card">
    <div class="list-panier" id="listPanier">
   
	<div class="loader-wrapper">
  <div class="loader"></div>
</div>
    </div>

        
    

        <div class="panier-total">
            Total : <strong id="totalPrice">0€</strong>
        </div>

        <div class="panier-actions">
            <a href="{{ path('app_produit') }}" class="btn-outline">
                Continuer vos achats
            </a>

            {% if app.user %}
                <a href="{{path('app_commande_client')}}" class="btn-gradient">
                    Payer ma commande
                </a>
            {% else %}
                <a href="{{path('app_register')}}" class="btn-gradient">
                    Creer un compte
                </a>
            {% endif %}
        </div>

    </div>

</div>

<script src="{{asset('javascripts/lsPanier.js')}}"></script>
<script src="{{asset('javascripts/panier.js')}}" defer></script>

{% endblock %}
