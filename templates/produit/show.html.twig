{% extends 'base.html.twig' %}

{% block title %}{{ produit.libelle }}{% endblock %}

{% block body %}
<link href="{{ asset('styles/showproduit.css') }}" rel="stylesheet" type="text/css"/>

<div class="product-page">

    <div class="product-gallery">
        {% for image in produit.image %}
            <img src="{{ image.url }}" alt="{{ produit.libelle }}">
        {% endfor %}
    </div>

    <div class="product-info">

    <h2 class="product-title">{{ produit.libelle }}</h2>

    <div class="product-badges">
        <span>Nouveau</span>
        <span>Qualité premium</span>
        
    </div>

    <div class="product-price">{{ produit.prix }} €</div>

    <ul class="product-features">
        <li>✔ Livraison rapide</li>
        <li>✔ Paiement sécurisé</li>
        <li>✔ Garantie 2 ans</li>
    </ul>

    <div class="product-description-box">
        <h4>Description</h4>
        <p>{{ produit.description }}</p>
    </div>

    <div class="product-meta">
        <div><strong>Référence :</strong> {{ produit.id }}</div>
        <div><strong>Catégorie :</strong> {{ produit.categorie.libelle ?? '—' }}</div>
        <br>
        
    </div>


        {% set say  = false %}

        {% for entrepot in entrepots %}
            {% if entrepot.web %}
                <span class="stock-type">Pour livraison :</span>
            {% elseif say == false %}
                {% set say = true %}
                <span class="stock-type">Pour Retrait en magasin :</span>
            {% endif %}

            <div class="entrepot-info">
                <div><strong>Stock :</strong> {{ entrepot.nom }}</div>

                {% if entrepot.quantite == 0 %}
                    <div class="stock-badge stock-unavailable">Rupture de stock</div>
                {% else %}
                    <div class="stock-badge stock-available">Quantité disponible : {{ entrepot.quantite }}</div>
                {% endif %}
            </div>






        {% endfor %}






























        
    <div class="product-actions">
        <button class="btn-add" onclick="tryToAdd({{ produit.id }}, '{{ produit.libelle }}')">Ajouter au panier</button>
        <a href="{{ path('app_produit') }}" class="btn-back">Retour</a>
    </div>

</div>


</div>
<script src="{{asset('javascripts/PANIER.js')}}"> </script>
<script src="{{asset('javascripts/accueil.js')}}" defer> </script>
{% endblock %}
