{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}

    <style>
/* =========================
   VARIABLES (optionnel mais propre)
========================= */
:root {
    --blue-gradient: linear-gradient(135deg, #cbd5ff, #a3bffa);
    --red-gradient: linear-gradient(135deg, #ffb3b3, #ff8c8c);
}

/* =========================
   FORM CONTAINER
========================= */
form[name="produit"] {
    max-width: 600px;
    margin: 40px auto;
    padding: 30px;

    display: flex;
    flex-direction: column;
    gap: 20px;

    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);

    border-radius: 18px;
    border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);

    animation: dropDown 0.8s ease-out;
}

/* =========================
   FIELD BLOCK
========================= */
#produit > div {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

/* =========================
   LABEL
========================= */
label {
    font-size: 14px;
    font-weight: 600;
    color: #333;
}

label.required::after {
    content: " *";
    color: #e53e3e;
}

/* =========================
   INPUT / TEXTAREA / SELECT
========================= */
input,
textarea,
select {
    padding: 10px 12px;
    border-radius: 8px;
    border: 2px solid transparent;

    font-size: 14px;
    color: #1f2937;

    outline: none;

    background:
        linear-gradient(white, white) padding-box,
        var(--blue-gradient) border-box;

    transition: all 0.25s ease;
}

/* Hover léger */
input:hover,
textarea:hover,
select:hover {
    transform: translateY(-1px);
}

/* Focus */
input:focus,
textarea:focus,
select:focus {
    box-shadow: 0 0 0 3px rgba(147, 197, 253, 0.4);
    transform: translateY(-2px);
}

/* =========================
   TEXTAREA
========================= */
textarea {
    min-height: 100px;
    resize: vertical;
}

/* =========================
   SELECT
========================= */
select {
    cursor: pointer;
}

.form-signin {
    display: flex;

    flex-direction: column;

    max-width: 400px;
}

/* =========================
   BUTTON
========================= */
.btn {
    margin-top: 10px;
    padding: 12px;

    border: none;
    border-radius: 12px;

    font-size: 15px;
    font-weight: 600;

    cursor: pointer;

    background: var(--red-gradient);
    color: #1f2937;

    transition: all 0.25s ease;
}

.btn:hover {
    transform: scale(1.05);
    opacity: 0.9;
}

/* =========================
   ANIMATION
========================= */
@keyframes dropDown {
    0% {
        opacity: 0;
        transform: translateY(-20px);
    }

    100% {
        opacity: 1;
        transform: translateY(0);
    }
}

/* =========================
   RESPONSIVE
========================= */
@media screen and (max-width: 768px) {
    form[name="produit"] {
        margin: 20px;
        padding: 20px;
    }
}
    </style>

    <div class="content">

    <form method="post" class="form-signin">
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
            </div>
        {% endif %}

        <h1 class="h3 mb-3 font-weight-normal">Please sign in</h1>
        <label for="username">Email</label>
        <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
        <label for="password">Password</label>
        <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        {#
            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
            See https://symfony.com/doc/current/security/remember_me.html

            <div class="checkbox mb-3">
                <input type="checkbox" name="_remember_me" id="_remember_me">
                <label for="_remember_me">Remember me</label>
            </div>
        #}

        <button class="btn btn-lg btn-primary" type="submit">
            Sign in
        </button>
    </form>

</div>

{% endblock %}
