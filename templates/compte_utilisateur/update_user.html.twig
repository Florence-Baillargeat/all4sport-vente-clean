{% extends 'base.html.twig' %}

{% block title %}Modifier mon compte - ALL4SPORT{% endblock %}

{% block body %}
<div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <h1 class="mb-4 text-center">Modifier mes informations</h1>

                {% for flash_error in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        {{ flash_error }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                {{ form_start(form, {
                    'attr': {
                        'class': 'needs-validation',
                        'novalidate': ''
                    }
                }) }}

                {# ─────────────────────────────────────────────── #}
                {# SECTION IDENTIFIANTS / CONNEXION                #}
                {# ─────────────────────────────────────────────── #}
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Identifiants de connexion</h5>
                    </div>
                    <div class="card-body">

                        <div class="mb-3">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                            <div class="form-text text-muted">
                                Laissez vide pour ne pas modifier votre adresse email.
                            </div>
                            {{ form_errors(form.email) }}
                        </div>

                        <hr class="my-4">

                        <div class="row g-3">
                            <div class="col-md-6">
                                {{ form_label(form.plainPassword.first) }}
                                {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control'}}) }}
                                <div class="form-text text-muted">
                                    Laissez vide si vous ne souhaitez pas changer votre mot de passe.
                                </div>
                                {{ form_errors(form.plainPassword.first) }}
                            </div>

                            <div class="col-md-6">
                                {{ form_label(form.plainPassword.second) }}
                                {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.plainPassword.second) }}
                            </div>
                        </div>

                    </div>
                </div>

                {# ─────────────────────────────────────────────── #}
                {# SECTION INFORMATIONS PERSONNELLES              #}
                {# ─────────────────────────────────────────────── #}
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Informations personnelles</h5>
                    </div>
                    <div class="card-body">

                        {{ form_row(form.nom, {
                            'attr': {'class': 'form-control'}
                        }) }}

                        {{ form_row(form.prenom, {
                            'attr': {'class': 'form-control'}
                        }) }}

                        {{ form_row(form.adresse, {
                            'attr': {'class': 'form-control'}
                        }) }}

                        {{ form_row(form.telephone, {
                            'attr': {'class': 'form-control'}
                        }) }}

                        {{ form_row(form.dateNaissance, {
                            'attr': {'class': 'form-control'}
                        }) }}

                        <div class="mt-4">
                            <label class="form-label fw-bold">Sports pratiqués</label>
                            <div class="border rounded p-3 bg-white">
                                {{ form_widget(form.sports) }}
                                {{ form_errors(form.sports) }}
                            </div>
                            <div class="form-text text-muted mt-2">
                                Sélectionnez un ou plusieurs sports (cases à cocher).
                            </div>
                        </div>

                    </div>
                </div>

                {# ─────────────────────────────────────────────── #}
                {# BOUTONS D'ACTION                               #}
                {# ─────────────────────────────────────────────── #}
                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                    <a href="{{ path('app_compte_utilisateur') }}" class="btn btn-outline-secondary px-4">
                        Annuler
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg px-5">
                        Enregistrer les modifications
                    </button>
                </div>

                {{ form_end(form) }}

                <div class="text-center mt-4">
                    <small class="text-muted">
                        Tous les champs sont optionnels. Laissez vide ce que vous ne voulez pas modifier.
                    </small>
                </div>

            </div>
        </div>
    </div>
{% endblock %}